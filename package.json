{
  "name": "taradiddle.news",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "opennextjs-cloudflare build",
    "start": "next start",
    "lint": "eslint",
    "preview": "opennextjs-cloudflare build && wrangler dev",
    "deploy": "opennextjs-cloudflare build && wrangler d1 migrations apply DB --remote && opennextjs-cloudflare deploy",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply DB --local",
    "db:migrate:remote": "wrangler d1 migrations apply DB --remote",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "db:seed:build": "node --experimental-strip-types src/db/build-seed.ts",
    "db:seed:local": "npm run db:seed:build && wrangler d1 execute DB --local --file=./seed.sql",
    "db:seed:remote": "npm run db:seed:build && wrangler d1 execute DB --remote --file=./seed.sql"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.0",
    "@opennextjs/cloudflare": "^1.19.11",
    "better-auth": "^1.6.15",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.17.0",
    "marked": "^18.0.5",
    "next": "16.2.8",
    "next-intl": "^4.13.0",
    "radix-ui": "^1.5.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "shadcn": "^4.11.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "better-sqlite3": "^12.10.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.8",
    "tailwindcss": "^4.3.0",
    "typescript": "^5",
    "vitest": "^4.1.8",
    "wrangler": "^4.99.0"
  }
}
